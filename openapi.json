{
  "openapi": "3.1.0",
  "info": {
    "title": "aivm-photo-api",
    "version": "0.2.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "ops"
        ],
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/images/upload": {
      "post": {
        "tags": [
          "images"
        ],
        "summary": "Upload Image",
        "operationId": "upload_image_images_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_image_images_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/images/recognize": {
      "post": {
        "tags": [
          "images"
        ],
        "summary": "Recognize Image",
        "operationId": "recognize_image_images_recognize_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_recognize_image_images_recognize_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecognizeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Body_recognize_image_images_recognize_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_recognize_image_images_recognize_post"
      },
      "Body_upload_image_images_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          },
          "sys": {
            "type": "integer",
            "maximum": 300.0,
            "minimum": 50.0,
            "title": "Sys"
          },
          "dia": {
            "type": "integer",
            "maximum": 200.0,
            "minimum": 30.0,
            "title": "Dia"
          },
          "pul": {
            "type": "integer",
            "maximum": 250.0,
            "minimum": 30.0,
            "title": "Pul"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          },
          "source": {
            "type": "string",
            "enum": [
              "local_ocr",
              "gemini",
              "gemini_auto",
              "manual",
              "user_confirmed"
            ],
            "title": "Source"
          },
          "corrected_by_user": {
            "type": "boolean",
            "title": "Corrected By User"
          },
          "device_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Device Model"
          },
          "ai_suggested_sys": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 300.0,
                "minimum": 50.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Ai Suggested Sys"
          },
          "ai_suggested_dia": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 200.0,
                "minimum": 30.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Ai Suggested Dia"
          },
          "ai_suggested_pul": {
            "anyOf": [
              {
                "type": "integer",
                "maximum": 250.0,
                "minimum": 30.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Ai Suggested Pul"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          },
          "ocr_meta": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/OcrMeta"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ocr Meta"
          }
        },
        "type": "object",
        "required": [
          "file",
          "sys",
          "dia",
          "pul",
          "timestamp",
          "source",
          "corrected_by_user"
        ],
        "title": "Body_upload_image_images_upload_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "RecognizeResponse": {
        "properties": {
          "sys": {
            "type": "integer",
            "title": "Sys"
          },
          "dia": {
            "type": "integer",
            "title": "Dia"
          },
          "pul": {
            "type": "integer",
            "title": "Pul"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "elapsed_ms": {
            "type": "integer",
            "title": "Elapsed Ms"
          }
        },
        "type": "object",
        "required": [
          "sys",
          "dia",
          "pul",
          "confidence",
          "elapsed_ms"
        ],
        "title": "RecognizeResponse"
      },
      "UploadResponse": {
        "properties": {
          "filename": {
            "type": "string",
            "title": "Filename"
          },
          "folder": {
            "type": "string",
            "title": "Folder"
          },
          "size_bytes": {
            "type": "integer",
            "title": "Size Bytes"
          }
        },
        "type": "object",
        "required": [
          "filename",
          "folder",
          "size_bytes"
        ],
        "title": "UploadResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "OcrConfidence": {
        "properties": {
          "min": {
            "title": "Min",
            "type": "number"
          },
          "mean": {
            "title": "Mean",
            "type": "number"
          }
        },
        "required": [
          "min",
          "mean"
        ],
        "title": "OcrConfidence",
        "type": "object"
      },
      "OcrInferenceMs": {
        "properties": {
          "display": {
            "title": "Display",
            "type": "integer"
          },
          "digits": {
            "title": "Digits",
            "type": "integer"
          },
          "postprocess": {
            "title": "Postprocess",
            "type": "integer"
          }
        },
        "required": [
          "display",
          "digits",
          "postprocess"
        ],
        "title": "OcrInferenceMs",
        "type": "object"
      },
      "OcrMeta": {
        "properties": {
          "engine": {
            "enum": [
              "local",
              "gemini",
              "manual"
            ],
            "title": "Engine",
            "type": "string"
          },
          "model_version": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Model Version"
          },
          "inference_ms": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/OcrInferenceMs"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "confidence": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/OcrConfidence"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "fallback_reason": {
            "anyOf": [
              {
                "enum": [
                  "low_confidence",
                  "no_display",
                  "wrong_row_count",
                  "user_requested"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Fallback Reason"
          },
          "user_agent": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "User Agent"
          },
          "hw_concurrency": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Hw Concurrency"
          }
        },
        "required": [
          "engine"
        ],
        "title": "OcrMeta",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}